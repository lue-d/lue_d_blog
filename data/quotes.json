[
  {
    "text": "长风破浪会有时，直挂云帆济沧海。",
    "source": "李白《行路难》"
  },
  {
    "text": "路漫漫其修远兮，吾将上下而求索。",
    "source": "屈原《离骚》"
  },
  {
    "text": "山重水复疑无路，柳暗花明又一村。",
    "source": "陆游《游山西村》"
  },
  {
    "text": "千磨万击还坚劲，任尔东西南北风。",
    "source": "郑燮《竹石》"
  },
  {
    "text": "会当凌绝顶，一览众山小。",
    "source": "杜甫《望岳》"
  },
  {
    "text": "宝剑锋从磨砺出，梅花香自苦寒来。",
    "source": "《警世贤文》"
  },
  {
    "text": "天行健，君子以自强不息。",
    "source": "《周易》"
  },
  {
    "text": "不以物喜，不以己悲。",
    "source": "范仲淹《岳阳楼记》"
  },
  {
    "text": "博观而约取，厚积而薄发。",
    "source": "苏轼"
  },
  {
    "text": "莫愁前路无知己，天下谁人不识君。",
    "source": "高适《别董大》"
  },
  {
    "text": "沉舟侧畔千帆过，病树前头万木春。",
    "source": "刘禹锡《酬乐天扬州初逢席上见赠》"
  },
  {
    "text": "天生我材必有用，千金散尽还复来。",
    "source": "李白《将进酒》"
  },
  {
    "text": "纸上得来终觉浅，绝知此事要躬行。",
    "source": "陆游《冬夜读书示子聿》"
  },
  {
    "text": "不畏浮云遮望眼，自缘身在最高层。",
    "source": "王安石《登飞来峰》"
  },
  {
    "text": "有志者事竟成，破釜沉舟，百二秦关终属楚。",
    "source": "蒲松龄"
  },
  {
    "text": "老骥伏枥，志在千里；烈士暮年，壮心不已。",
    "source": "曹操《龟虽寿》"
  },
  {
    "text": "海纳百川，有容乃大；壁立千仞，无欲则刚。",
    "source": "林则徐"
  },
  {
    "text": "绳锯木断，水滴石穿。",
    "source": "《汉书》"
  },
  {
    "text": "失之东隅，收之桑榆。",
    "source": "《后汉书》"
  },
  {
    "text": "长风万里送秋雁，对此可以酣高楼。",
    "source": "李白"
  },
  {
    "text": "古之立大事者，不惟有超世之才，亦必有坚忍不拔之志。",
    "source": "苏轼《晁错论》"
  },
  {
    "text": "业精于勤，荒于嬉；行成于思，毁于随。",
    "source": "韩愈《进学解》"
  },
  {
    "text": "宠辱不惊，看庭前花开花落；去留无意，望天上云卷云舒。",
    "source": "《菜根谭》"
  },
  {
    "text": "合抱之木，生于毫末；九层之台，起于累土；千里之行，始于足下。",
    "source": "老子《道德经》"
  },
  {
    "text": "岁寒，然后知松柏之后凋也。",
    "source": "《论语》"
  },
  {
    "text": "大鹏一日同风起，扶摇直上九万里。",
    "source": "李白《上李邕》"
  },
  {
    "text": "山不在高，有仙则名；水不在深，有龙则灵。",
    "source": "刘禹锡《陋室铭》"
  },
  {
    "text": "非淡泊无以明志，非宁静无以致远。",
    "source": "诸葛亮《诫子书》"
  },
  {
    "text": "问渠那得清如许，为有源头活水来。",
    "source": "朱熹《观书有感》"
  },
  {
    "text": "等闲识得东风面，万紫千红总是春。",
    "source": "朱熹《春日》"
  },
  {
    "text": "欲穷千里目，更上一层楼。",
    "source": "王之涣《登鹳雀楼》"
  },
  {
    "text": "苔花如米小，也学牡丹开。",
    "source": "袁枚《苔》"
  },
  {
    "text": "人生如逆旅，我亦是行人。",
    "source": "苏轼《临江仙》"
  },
  {
    "text": "世事洞明皆学问，人情练达即文章。",
    "source": "《红楼梦》"
  },
  {
    "text": "他山之石，可以攻玉。",
    "source": "《诗经》"
  },
  {
    "text": "千淘万漉虽辛苦，吹尽狂沙始到金。",
    "source": "刘禹锡《浪淘沙》"
  },
  {
    "text": "读书破万卷，下笔如有神。",
    "source": "杜甫"
  },
  {
    "text": "众里寻他千百度，蓦然回首，那人却在灯火阑珊处。",
    "source": "辛弃疾《青玉案·元夕》"
  },
  {
    "text": "落红不是无情物，化作春泥更护花。",
    "source": "龚自珍《己亥杂诗》"
  },
  {
    "text": "少年易老学难成，一寸光阴不可轻。",
    "source": "朱熹《劝学诗》"
  },
  {
    "text": "雄关漫道真如铁，而今迈步从头越。",
    "source": "毛泽东《忆秦娥·娄山关》"
  },
  {
    "text": "君子藏器于身，待时而动。",
    "source": "《周易》"
  },
  {
    "text": "操千曲而后晓声，观千剑而后识器。",
    "source": "刘勰《文心雕龙》"
  },
  {
    "text": "看似寻常最奇崛，成如容易却艰辛。",
    "source": "王安石"
  },
  {
    "text": "桃李不言，下自成蹊。",
    "source": "《史记》"
  },
  {
    "text": "青，取之于蓝而青于蓝；冰，水为之而寒于水。",
    "source": "荀子《劝学》"
  },
  {
    "text": "采菊东篱下，悠然见南山。",
    "source": "陶渊明《饮酒》"
  },
  {
    "text": "一点浩然气，千里快哉风。",
    "source": "苏轼《水调歌头》"
  },
  {
    "text": "人生自古谁无死，留取丹心照汗青。",
    "source": "文天祥《过零丁洋》"
  },
  {
    "text": "锲而不舍，金石可镂。",
    "source": "荀子《劝学》"
  },
  {
    "text": "心之所向，素履以往；生如逆旅，一苇以航。",
    "source": "《尘曲》"
  },
  {
    "text": "每一个不曾起舞的日子，都是对生命的辜负。",
    "source": "尼采"
  },
  {
    "text": "世界以痛吻我，我要报之以歌。",
    "source": "泰戈尔"
  },
  {
    "text": "生活不止眼前的苟且，还有诗和远方。",
    "source": "高晓松"
  },
  {
    "text": "愿你出走半生，归来仍是少年。",
    "source": "《愿你》"
  },
  {
    "text": "心存希冀，目有繁星；追光而遇，沐光而行。",
    "source": "佚名"
  },
  {
    "text": "但行好事，莫问前程。",
    "source": "《增广贤文》"
  },
  {
    "text": "星光不问赶路人，时光不负有心人。",
    "source": "佚名"
  },
  {
    "text": "慢慢来，会更快。",
    "source": "佚名"
  },
  {
    "text": "你所热爱的，就是你的生活。",
    "source": "佚名"
  }
]
